{
  "name": "mwrd",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.client.ts",
    "dev:client": "vite --config vite.config.client.ts",
    "dev:supplier": "vite --config vite.config.supplier.ts",
    "dev:backoffice": "vite --config vite.config.backoffice.ts",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.convex.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:all": "playwright test --config playwright.all.config.ts",
    "test:e2e:anonymity": "playwright test e2e/anonymity.leakage.spec.ts",
    "build": "pnpm build:client && pnpm build:supplier && pnpm build:backoffice",
    "build:client": "tsc -p tsconfig.app.json --noEmit && vite build --config vite.config.client.ts",
    "build:supplier": "tsc -p tsconfig.app.json --noEmit && vite build --config vite.config.supplier.ts",
    "build:backoffice": "tsc -p tsconfig.app.json --noEmit && vite build --config vite.config.backoffice.ts",
    "seed": "convex run seed:seedDevelopmentData",
    "seed:load": "convex run seed:seedLoadTestData",
    "seed:products": "node scripts/seed-master-products.mjs",
    "load-test": "node scripts/load-test.mjs",
    "preview:client": "vite preview --config vite.config.client.ts",
    "preview:supplier": "vite preview --config vite.config.supplier.ts",
    "preview:backoffice": "vite preview --config vite.config.backoffice.ts"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.12.0",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "^1.3.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.28.0",
    "i18next": "^25.6.0",
    "lucide-react": "^0.552.0",
    "posthog-js": "^1.294.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-i18next": "^16.2.0",
    "react-router-dom": "^7.9.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.9.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^27.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vitest": "^3.2.4"
  }
}
